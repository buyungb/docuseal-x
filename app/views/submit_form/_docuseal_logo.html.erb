<% custom_logo_url = current_account&.account_configs&.find_by(key: 'company_logo_url')&.value rescue nil %>
<% custom_name = current_account&.account_configs&.find_by(key: 'company_name')&.value rescue nil %>
<a href="<%= root_path %>" class="mx-auto text-2xl md:text-3xl font-bold items-center flex space-x-3">
  <% if custom_logo_url.present? %>
    <img src="<%= custom_logo_url %>" alt="<%= custom_name || 'Logo' %>" class="w-9 h-9 md:w-12 md:h-12 object-contain">
  <% else %>
    <%= render 'shared/logo', class: 'w-9 h-9 md:w-12 md:h-12' %>
  <% end %>
  <span><%= custom_name.presence || Docuseal.product_name %></span>
</a>
