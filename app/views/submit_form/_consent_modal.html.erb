<%
  consent_cookie_name = "consent_accepted_#{submitter_slug}"
  already_accepted = cookies[consent_cookie_name] == 'true' ||
                     @submitter.submission_events.exists?(event_type: 'accept_consent')
%>
<% unless already_accepted %>
<div id="consent_overlay"
     class="fixed inset-0 bg-black bg-opacity-50 z-[100] flex items-center justify-center p-4"
     data-consent-endpoint="<%= submit_form_consent_index_path(submit_form_slug: submitter_slug) %>"
     data-consent-cookie="<%= consent_cookie_name %>"
     data-csrf-token="<%= form_authenticity_token %>">
  <div class="bg-base-100 rounded-lg shadow-xl max-w-md w-full p-6">
    <h2 class="text-xl font-bold mb-4"><%= t('consent_required') %></h2>
    <p class="text-base-content/70 mb-4">
      <%= t('before_proceeding_please_review_and_accept_the_terms') %>
    </p>
    
    <div class="mb-4">
      <a href="<%= consent_url %>" target="_blank" class="btn btn-outline btn-sm gap-2">
        <%= svg_icon('external_link', class: 'w-4 h-4') %>
        <%= t('view_document') %>
      </a>
    </div>
    
    <div class="form-control mb-4">
      <label class="cursor-pointer flex items-start gap-3">
        <input type="checkbox" id="consent_checkbox" class="checkbox checkbox-primary mt-1" />
        <span class="label-text text-sm">
          <%= consent_text.presence || t('i_have_read_and_agree_to_the_terms_and_conditions') %>
        </span>
      </label>
    </div>
    
    <button id="consent_accept_btn" class="btn btn-primary w-full btn-disabled" type="button">
      <%= t('continue') %>
    </button>
  </div>
</div>

<script type="text/javascript" nonce="<%= content_security_policy_nonce %>">
  (function() {
    var consentCheckbox = document.getElementById('consent_checkbox');
    var consentAcceptBtn = document.getElementById('consent_accept_btn');
    var consentOverlay = document.getElementById('consent_overlay');

    if (!consentCheckbox || !consentAcceptBtn || !consentOverlay) return;

    var endpoint = consentOverlay.getAttribute('data-consent-endpoint');
    var csrfToken = consentOverlay.getAttribute('data-csrf-token');
    var cookieName = consentOverlay.getAttribute('data-consent-cookie') || 'consent_accepted';

    consentCheckbox.addEventListener('change', function() {
      if (this.checked) {
        consentAcceptBtn.classList.remove('btn-disabled');
        consentAcceptBtn.removeAttribute('disabled');
      } else {
        consentAcceptBtn.classList.add('btn-disabled');
        consentAcceptBtn.setAttribute('disabled', 'disabled');
      }
    });

    function dismissOverlay() {
      document.cookie = cookieName + '=true; path=/; max-age=86400; SameSite=Lax';
      if (consentOverlay && consentOverlay.parentNode) {
        consentOverlay.parentNode.removeChild(consentOverlay);
      }
    }

    consentAcceptBtn.addEventListener('click', function(e) {
      e.preventDefault();
      if (!consentCheckbox.checked) return;

      consentAcceptBtn.classList.add('btn-disabled');
      consentAcceptBtn.setAttribute('disabled', 'disabled');

      // Record the consent server-side (IP, UA, timestamp, document URL+text)
      // before dismissing the overlay so it is captured in the audit trail.
      fetch(endpoint, {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
          'Accept': 'application/json',
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrfToken
        },
        body: '{}'
      }).then(function() {
        dismissOverlay();
      }).catch(function() {
        // Fail-open: if the logging request fails (e.g. offline), still let the
        // user proceed — the cookie gate remains and we do not want to block
        // signing on a transient network error.
        dismissOverlay();
      });
    });
  })();
</script>
<% end %>
