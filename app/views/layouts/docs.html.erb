<!DOCTYPE html>
<html data-theme="docuseal" lang="<%= I18n.locale %>">
  <head>
    <%= render 'layouts/head_tags' %>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%= csrf_meta_tags %>
    <% if ENV['ROLLBAR_CLIENT_TOKEN'] %>
      <meta name="rollbar-token" content="<%= ENV.fetch('ROLLBAR_CLIENT_TOKEN', nil) %>">
      <%= javascript_pack_tag 'rollbar', 'application', defer: true %>
    <% else %>
      <%= javascript_pack_tag 'application', defer: true %>
    <% end %>
    <%= stylesheet_pack_tag 'application', media: 'all' %>
  </head>
  <body class="min-h-screen bg-base-200">
    <header class="border-b border-base-300 bg-base-100">
      <div class="max-w-6xl mx-auto px-4 py-3 flex flex-wrap items-center justify-between gap-3">
        <div class="flex items-center gap-4">
          <a href="<%= root_path %>" class="text-xl font-bold text-base-content"><%= Docuseal.product_name %></a>
          <nav class="hidden sm:flex items-center gap-3 text-sm font-medium">
            <%= link_to 'API', api_docs_path, class: 'hover:text-primary' %>
            <%= link_to 'Template tags', template_tags_docs_path, class: 'hover:text-primary' %>
            <%= link_to 'Pricing', pricing_path, class: 'hover:text-primary' %>
            <%= link_to 'Use cases', use_cases_path, class: 'hover:text-primary' %>
          </nav>
        </div>
        <div class="flex items-center gap-2 text-sm">
          <%= link_to t('sign_in'), new_user_session_path({ lang: params[:lang] }.compact_blank), class: 'btn btn-ghost btn-sm' unless signed_in? %>
        </div>
      </div>
    </header>
    <main class="pb-16">
      <%= yield %>
    </main>
    <%= render 'shared/body_scripts' %>
  </body>
</html>
