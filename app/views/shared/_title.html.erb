<% custom_logo_url = current_account&.account_configs&.find_by(key: 'company_logo_url')&.value %>
<% custom_name = current_account&.account_configs&.find_by(key: 'company_name')&.value %>
<% if custom_logo_url.present? %>
  <img src="<%= custom_logo_url %>" alt="<%= custom_name || 'Logo' %>" class="w-9 h-9 object-contain">
<% else %>
  <%= render 'shared/logo' %>
<% end %>
<span><%= custom_name.presence || Docuseal.product_name %></span>
