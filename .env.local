# Copy this file to .env.local and adjust the values before running deploy-local.sh.

# --- Web ---------------------------------------------------------------------
APP_PORT=9090
APP_URL=http://localhost:9090
HOST=localhost
# FORCE_SSL=                # leave empty for local http

# --- Postgres (host port mapping; container always uses 5432 internally) -----
POSTGRES_PORT=5433

# --- Rails -------------------------------------------------------------------
SECRET_KEY_BASE=ff471b1b87437f3d4bacbceec04451ddcfd5e8e84e4f9c3d6a53bf202cebedfd5659eb75dc222a05c8f32626395688146021226ddd74bb188e3a77d278a1a93c
RAILS_LOG_LEVEL=info

# --- Aplindo licensing -------------------------------------------------------
APLINDO_LICENSE_API_URL=http://host.docker.internal:8080
APLINDO_LICENSE_PRODUCT_SLUG=SealRoute
APLINDO_LICENSE_DEFAULT_AMOUNT_IDR=5000000.00
